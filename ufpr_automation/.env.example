# ============================================================================
# UFPR Automation — Environment Variables
# ============================================================================
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
#
# NEVER commit the `.env` file to version control!
# ============================================================================

# --- Gemini API Key (or other LLM provider) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- LLM Model Configuration ---
# Easily swappable — change to any model supported by nanobot/litellm
# Examples: gemini/gemini-1.5-pro, gemini/gemini-1.5-flash, openrouter/google/gemini-pro
LLM_MODEL=gemini/gemini-1.5-pro
LLM_PROVIDER=gemini

# --- Outlook Web Access (OWA) URLs ---
OWA_URL=https://outlook.office365.com/mail/
OWA_INBOX_URL=https://outlook.cloud.microsoft/mail/?msalAuthRedirect=true

# --- Browser Settings ---
BROWSER_TIMEOUT_MS=60000
LOGIN_TIMEOUT_MS=300000
