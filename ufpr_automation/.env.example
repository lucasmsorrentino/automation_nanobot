# =============================================================================
# UFPR Automation — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# ---------------------------------------------------------------------------
# Email Channel — which source to read emails from
# "gmail" = Gmail API via IMAP (primary, no MFA needed)
# "owa"   = Outlook Web Access via Playwright (fallback, requires MFA)
# ---------------------------------------------------------------------------
EMAIL_CHANNEL=gmail

# ---------------------------------------------------------------------------
# Gmail (primary channel — receives forwarded emails from Outlook UFPR)
# Enable 2FA on Gmail → generate App Password → paste here
# ---------------------------------------------------------------------------
GMAIL_EMAIL=design.grafico.ufpr@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
GMAIL_API_KEY=AIzaSyA1vHI-Fc6zr6B_QxYOMUbbW0EYMwYqRjg

# ---------------------------------------------------------------------------
# OWA Login Credentials (fallback channel — automated Playwright login)
# ---------------------------------------------------------------------------
OWA_EMAIL=seu.email@ufpr.br
OWA_PASSWORD=sua_senha_aqui

# OWA URLs (defaults work for Office 365 — change only if needed)
# OWA_URL=https://outlook.office365.com/mail/
# OWA_INBOX_URL=https://outlook.cloud.microsoft/mail/?msalAuthRedirect=true

# ---------------------------------------------------------------------------
# Telegram Notification (for MFA number-match when using OWA channel)
# Get bot token from @BotFather, chat ID from @userinfobot or similar
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklmNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# ---------------------------------------------------------------------------
# SIGA — Sistema de Gestão Acadêmica (Marco III)
# ---------------------------------------------------------------------------
# SIGA_URL=https://www.prppg.ufpr.br/siga/
SIGA_USERNAME=seu_usuario_siga
SIGA_PASSWORD=sua_senha_siga

# ---------------------------------------------------------------------------
# SEI — Sistema Eletrônico de Informações (Marco III)
# ---------------------------------------------------------------------------
# SEI_URL=https://sei.ufpr.br/
SEI_USERNAME=seu_usuario_sei
SEI_PASSWORD=sua_senha_sei

# ---------------------------------------------------------------------------
# LLM Provider (MiniMax via LiteLLM for email classification + response)
# ---------------------------------------------------------------------------
MINIMAX_API_KEY=your_minimax_api_key_here
# LLM_MODEL=minimax/MiniMax-M2
# LLM_PROVIDER=minimax

# Legacy Gemini (optional fallback)
# GEMINI_API_KEY=your_gemini_api_key_here

# ---------------------------------------------------------------------------
# Model Cascading (Marco III — optional, requires local Ollama or second API)
# Routes classification to a cheap/local model, drafting to a capable API model.
# Leave empty to use LLM_MODEL for everything (default behavior).
# ---------------------------------------------------------------------------
# LLM_CLASSIFY_MODEL=ollama/qwen3:8b        # cheap/local for classification
# LLM_DRAFT_MODEL=minimax/MiniMax-M2        # capable API for drafting
# LLM_FALLBACK_MODEL=minimax/MiniMax-M2     # last resort if primary fails
# LLM_CASCADE_RETRIES=2                     # retries before falling back
# LLM_TIMEOUT_SECONDS=120                   # timeout per LLM call

# ---------------------------------------------------------------------------
# Email Signature (appended to generated drafts)
# ---------------------------------------------------------------------------
# ASSINATURA_EMAIL=Atenciosamente,\nSeu Nome\nSetor X — UFPR

# ---------------------------------------------------------------------------
# RAG — Vector store and documents directories
# Override to share the store via network/cloud (Google Drive, NAS, etc.)
# After installing Google Drive for Desktop, it mounts at G:\ by default.
# ---------------------------------------------------------------------------
# RAG_STORE_DIR=G:/Meu Drive/ufpr_rag/store   (pt-BR)
# RAG_STORE_DIR=G:/My Drive/ufpr_rag/store     (en)
# RAG_DOCS_DIR=G:/Meu Drive/ufpr_rag/docs
# RAG_DOCS_DIR=G:/My Drive/ufpr_rag/docs

# ---------------------------------------------------------------------------
# Browser Settings (milliseconds — defaults should be fine)
# ---------------------------------------------------------------------------
# BROWSER_TIMEOUT_MS=60000
# LOGIN_TIMEOUT_MS=300000
